rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/partecipanti/$(request.auth.uid)).data.isAdmin == true;
    }

    function isApprovato() {
      let d = get(/databases/$(database)/documents/partecipanti/$(request.auth.uid)).data;
      return isAuth() && d.approvato == true && d.get('disabilitato', false) != true;
    }

    // ── PARTECIPANTI ──────────────────────────────────
    match /partecipanti/{uid} {
      // Lettura: ognuno può leggere il proprio profilo (serve per controllare approvato);
      //          gli admin leggono tutti.
      allow read: if isAuth() && (request.auth.uid == uid || isAdmin());

      // Creazione: un utente autenticato può creare SOLO il proprio documento,
      //            con approvato: false obbligatorio (non può auto-approvarsi).
      allow create: if isAuth()
        && request.auth.uid == uid
        && request.resource.data.approvato == false
        && request.resource.data.isAdmin == false;

      // Aggiornamento: admin possono modificare tutto (approvazione, correzioni).
      // Un utente con isOwner:true può essere modificato SOLO da se stesso.
      // Un utente approvato può aggiornare SOLO il proprio nickname.
      allow update: if (isAdmin() && (
                      !resource.data.get('isOwner', false) ||
                      request.auth.uid == uid
                    )) ||
                    (isApprovato()
                      && request.auth.uid == uid
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nickname']));

      // Cancellazione: solo admin (rifiuto richieste).
      allow delete: if isAdmin();
    }

    // ── PRONOSTICI ────────────────────────────────────
    // Tutti gli approvati possono leggere (per vedere le schede altrui dalla classifica).
    // Solo il proprietario può scrivere la propria scheda.
    match /pronostici/{uid} {
      allow read:  if isApprovato();
      allow write: if isApprovato() && request.auth.uid == uid;
    }

    // ── RISULTATI ─────────────────────────────────────
    match /risultati/{doc} {
      allow read: if isApprovato();
      allow write: if isAdmin(); // Admin può scrivere (sync API + simulazioni manuali)
    }

    // ── CLASSIFICA ────────────────────────────────────
    match /classifica/{doc} {
      allow read: if isApprovato();
      // Admin: scrittura completa. Approvati: solo aggiornamento snapshot (per cambio nickname).
      allow write: if isAdmin() || isApprovato();
    }

    // ── LIVE ──────────────────────────────────────────
    match /live/{doc} {
      allow read: if isApprovato();
      allow write: if false;
    }

    // ── SISTEMA / CONFIG ──────────────────────────────
    match /sistema/{doc} {
      allow read:  if isAuth(); // anche non approvati (serve per sapere se pronostici aperti)
      allow write: if isAdmin();
    }
  }
}
